# Amazon BSR Tracker - Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application
COPY amazon_tracker.py .

# Expose port
EXPOSE 8000

# Run application
CMD ["uvicorn", "amazon_tracker:app", "--host", "0.0.0.0", "--port", "8000"]
