# ─── YOUR WALLET (where USDC payments arrive) ───
# Solana wallet address (required)
WALLET_ADDRESS=YOUR_SOLANA_WALLET_ADDRESS_HERE
# Base wallet address (optional — defaults to WALLET_ADDRESS if not set)
WALLET_ADDRESS_BASE=YOUR_BASE_WALLET_ADDRESS_HERE

# ─── SERVICE CONFIG ───
SERVICE_NAME=instagram-intelligence-api
SERVICE_DESCRIPTION=Instagram Intelligence + AI Vision Analysis. Profile data, engagement metrics, AI content classification, fake detection. Powered by real 4G/5G mobile proxies.
PORT=3000
RATE_LIMIT=60

# ─── PROXY CREDENTIALS ───
# Get from https://client.proxies.sx or buy via x402 API:
#   curl https://api.proxies.sx/v1/x402/proxy?country=US&traffic=1
PROXY_HOST=
PROXY_HTTP_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_COUNTRY=US

# ─── AI VISION MODEL (required for /analyze and /audit endpoints) ───
# Get your API key from https://platform.openai.com
OPENAI_API_KEY=sk-...

# ─── OPTIONAL: Custom RPC endpoints ───
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# BASE_RPC_URL=https://mainnet.base.org
