# ─── Required ───────────────────────────────────────
# Your Solana wallet address for USDC payments
WALLET_ADDRESS=your_solana_wallet_address_here

# Proxies.sx credentials (get from client.proxies.sx)
PROXY_HOST=proxy.proxies.sx
PROXY_HTTP_PORT=8000
PROXY_USER=your_proxy_username
PROXY_PASS=your_proxy_password
PROXY_COUNTRY=US

# ─── Optional ────────────────────────────────────────
# Multiple proxies (semicolon-separated: host:port:user:pass:country)
# PROXY_LIST=host1:8000:user1:pass1:US;host2:8000:user2:pass2:GB

# Base network wallet (EVM address for Base USDC payments)
# WALLET_ADDRESS_BASE=0xYourBaseWalletAddress

# Rate limiting (requests per minute per IP)
RATE_LIMIT=60

# Port
PORT=3000

# Custom RPC endpoints (optional)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# BASE_RPC_URL=https://mainnet.base.org
