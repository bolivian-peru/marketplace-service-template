# ─── YOUR WALLET (where USDC payments arrive) ───
# Solana wallet address (required)
WALLET_ADDRESS=
# Base wallet address (optional — defaults to WALLET_ADDRESS if not set)
WALLET_ADDRESS_BASE=

# ─── SERVICE CONFIG ───
# Prediction Market Aggregator (Primary Service)
SERVICE_NAME=prediction-market-aggregator
SERVICE_DESCRIPTION=Real-time prediction market aggregator (Polymarket, Kalshi, Metaculus) with social sentiment signals using mobile proxies.
PRICE_USDC=0.05

# Google Maps Lead Generator (Alternative Example)
MAPS_SERVICE_NAME=google-maps-lead-generator
MAPS_PRICE_USDC=0.005

# Mobile SERP Tracker (Alternative Example)
SERP_SERVICE_NAME=mobile-serp-tracker
SERP_PRICE_USDC=0.003

PORT=3000
RATE_LIMIT=60

# ─── PROXY CREDENTIALS ───
# Get from https://client.proxies.sx or buy via x402 API:
#   curl https://api.proxies.sx/v1/x402/proxy?country=US&traffic=1
PROXY_HOST=
PROXY_HTTP_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_COUNTRY=US

# ─── REQUIRED: Antidetect browser API ───
# This service uses browser rendering (not regex) to scrape Google/Twitter reliably.
# Browser mode is REQUIRED - get your key from proxies.sx dashboard
BROWSER_ENDPOINT=https://browser.proxies.sx
BROWSER_PAYMENT_SIG=

# ─── OPTIONAL: Custom RPC endpoints ───
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# BASE_RPC_URL=https://mainnet.base.org
