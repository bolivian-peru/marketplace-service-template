{
  \"name\": \"Airbnb Intelligence API (Bounty #78)\",
  \"description\": \"Airbnb listing intelligence: search results, individual listing details, market stats, and reviews scraping via proxy.\",
  \"version\": \"0.1.0\",
  \"price_usdc\": 0.005,
  \"input_schema\": {
    \"search\": {
      \"location\": \"string (city/market)\",
      \"checkin\": \"YYYY-MM-DD\",
      \"checkout\": \"YYYY-MM-DD\",
      \"guests\": \"number (default 2)\",
      \"limit\": \"number (default 20)\"
    },
    \"listing\": {
      \"listingId\": \"string (Airbnb listing ID)\"
    }
  },
  \"output_schema\": {
    \"search\": {
      \"listings\": [
        {
          \"id\": \"string\",
          \"name\": \"string\",
          \"summary\": \"string\",
          \"price\": {
            \"night\": \"number\",
            \"total\": \"number\",
            \"currency\": \"string\"
          },
          \"rating\": \"number\",
          \"reviews\": \"number\",
          \"beds\": \"number\",
          \"bathrooms\": \"number\",
          \"bedrooms\": \"number\",
          \"url\": \"string\",
          \"images\": [\"string\"],
          \"location\": {
            \"lat\": \"number\",
            \"lng\": \"number\"
          }
        }
      ]
    },
    \"listing\": {
      \"id\": \"string\",
      \"host\": {
        \"name\": \"string\",
        \"isSuperhost\": \"boolean\",
        \"responseRate\": \"string\"
      },
      \"reviews\": [...] 
    }
  },
  \"endpoints\": [
    \"/api/airbnb/health\",
    \"/api/airbnb/search\",
    \"/api/airbnb/listing/:id\",
    \"/api/airbnb/stats\"
  ],
  \"deployed_at\": \"https://airbnb-intelligence.onrender.com\",
  \"proof\": \"proof/airbnb/\"
}