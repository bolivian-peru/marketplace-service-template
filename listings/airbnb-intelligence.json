{
  "$schema": "https://platform.fusotao.com/schemas/service.json",
  "name": "Airbnb Intelligence API",
  "description": "Real-time Airbnb market intelligence: search listings, extract pricing/reviews/occupancy stats by city/query. Structured JSON output for listings, market stats, trends.",
  "version": "0.1.0",
  "endpoints": [
    {
      "path": "/api/airbnb/health",
      "method": "GET",
      "description": "Service health check (no auth)",
      "response": { "type": "json", "schema": "health" }
    },
    {
      "path": "/api/airbnb/intelligence",
      "method": "GET",
      "description": "Search listings by city/query (paid: x402 gated)",
      "params": [
        { "name": "city", "type": "string", "required": true },
        { "name": "query", "type": "string" },
        { "name": "limit", "type": "number", "default": 20 }
      ],
      "response": { "type": "json", "schema": "airbnb-listings" }
    },
    {
      "path": "/api/airbnb/listing/:id",
      "method": "GET",
      "description": "Fetch single listing details/reviews (paid)",
      "response": { "type": "json", "schema": "airbnb-listing" }
    }
  ],
  "pricing": {
    "tiers": [
      { "name": "free", "quota": "5 req/day", "endpoints": ["/health"] },
      { "name": "basic", "$10/mo", "quota": "1000 req/mo" },
      { "name": "pro", "$50/mo", "unlimited" }
    ]
  },
  "deploy": "https://airbnb-intel.onrender.com",
  "bounty": "#78"
}